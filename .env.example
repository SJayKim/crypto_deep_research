# Coin data source credentials — copy this file to `.env` and fill in.
# Never commit the real `.env`.

# CoinGecko  (https://www.coingecko.com/en/api)  — Demo or Pro key
COINGECKO_API_KEY=

# Binance  (https://www.binance.com/en/my/settings/api-management)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Upbit  (https://upbit.com/mypage/open_api_management)
UPBIT_ACCESS_KEY=
UPBIT_SECRET_KEY=

# Anthropic  (LangGraph agents)
ANTHROPIC_API_KEY=

# --- Service wiring (M0) ---
# MCP server (coin-data tools) base URL — required.
MCP_URL=http://127.0.0.1:8000/mcp

# Worker A2A service URLs — comma-separated, data-driven registry (required).
# Append one URL per worker; the orchestrator reads this list, no code edit needed.
WORKER_URLS=http://127.0.0.1:8101,http://127.0.0.1:8102,http://127.0.0.1:8103,http://127.0.0.1:8104

# Per-worker dispatch timeout in seconds (A3; defaults to 30 if unset).
WORKER_TIMEOUT_S=30

# --- Memory (M4) ---
# Directory for the SQLite memory DBs (orchestrator episodic+long-term + per-worker
# checkpointers, A4). Created on first run; defaults to .memory if unset.
MEMORY_DIR=.memory

# --- Live data source (M5) ---
# Which DataSource the MCP server serves: `coingecko` makes get_ohlcv live (other 3 tools
# stay on fixtures); anything else (default) keeps all 4 on fixtures.
COIN_DATA_SOURCE=fixture
