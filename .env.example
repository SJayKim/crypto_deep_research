# Coin data source credentials — copy this file to `.env` and fill in.
# Never commit the real `.env`.

# CoinGecko  (https://www.coingecko.com/en/api)  — Demo or Pro key
COINGECKO_API_KEY=

# Binance  (https://www.binance.com/en/my/settings/api-management)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Upbit  (https://upbit.com/mypage/open_api_management)
UPBIT_ACCESS_KEY=
UPBIT_SECRET_KEY=

# Anthropic  (LangGraph agents)
ANTHROPIC_API_KEY=
